{
	"crons": [
		{
			"path": "/api/process-feed",
			"schedule": "45 16 * * *"
		},
		{
			"path": "/api/newsletter/send",
			"schedule": "0 6 * * 1"
		}
	],
	"builds": [
		{
			"src": "package.json",
			"use": "@vercel/next"
		}
	],
	"buildCommand": "prisma generate && next build",
	"installCommand": "npm install"
}
